### Track ONLY the custom theme: `wp-content/themes/abilityworks21/`

# Ignore everything by default.
/*

# But keep this file tracked.
!/.gitignore

# Allow traversing into the theme path.
!/wp-content/
!/wp-content/themes/
!/wp-content/themes/abilityworks21/

# Track all theme files.
!/wp-content/themes/abilityworks21/**

# OS cruft (kept here for clarity; already ignored by /* above).
.DS_Store
wp-content/.DS_Store
